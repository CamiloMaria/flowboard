# ── FlowBoard Production Environment ──────────────────────────
# Copy this file to .env on the server: cp .env.production.example .env
# Then fill in the values below.

# PostgreSQL password (generate: openssl rand -base64 24)
POSTGRES_PASSWORD=CHANGE_ME

# Redis password (generate: openssl rand -base64 24)
REDIS_PASSWORD=CHANGE_ME

# JWT Secrets (generate each: openssl rand -base64 32)
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# Frontend URL on Vercel (for CORS)
CORS_ORIGIN=https://your-flowboard.vercel.app
